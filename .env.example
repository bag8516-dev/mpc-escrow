# ★ 실제 배포 시 이 파일을 .env 로 복사하고 값을 입력하세요
# ★ .env 파일은 절대 공유하거나 Git에 커밋하지 마세요

# 배포에 사용할 지갑 개인키 (0x 포함)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polygonscan API 키 (컨트랙트 검증용, https://polygonscan.com/apis)
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# 멀티시그 소유자 주소 (최소 2개, 쉼표 구분)
MULTISIG_OWNER_1=0xADDRESS_1
MULTISIG_OWNER_2=0xADDRESS_2
MULTISIG_OWNER_3=0xADDRESS_3
